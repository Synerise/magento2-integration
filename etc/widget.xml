<widgets xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Widget:etc/widget.xsd">
    <widget id="synerise_product_recommendations" class="Synerise\Integration\Block\Widget\Recommendations\Resolver"
            placeholder_image="Magento_CatalogWidget::images/products_list.png" ttl="86400">
        <label translate="true">Synerise Product Recommendations</label>
        <description translate="true">List of Products provided by recommendations campaign</description>
        <parameters>
            <parameter name="title" xsi:type="text" required="false" visible="true">
                <label translate="true">Title</label>
            </parameter>
            <parameter name="campaign_id" xsi:type="text" required="true" visible="true">
                <label translate="true">Campaign index</label>
            </parameter>
            <parameter name="static" xsi:type="select">
                <label>Static</label>
                <description translate="true">
                    <![CDATA[Recommendations are loaded dynamically via ajax by default.
                    <br/>Static recommendations are not personalised. Use only with campaigns that do not require user context.]]>
                </description>
                <options>
                    <option name="no" value="0" selected="true">
                        <label translate="true">No</label>
                    </option>
                    <option name="yes" value="1">
                        <label translate="true">Yes</label>
                    </option>
                </options>
            </parameter>
            <parameter name="layout_handle" xsi:type="text" required="false" visible="true">
                <label translate="true">Layout Handle</label>
                <description translate="true">
                    <![CDATA[Custom layout handle for advanced customization.
                    <br/>Leave empty to use default layout.]]>
                </description>
            </parameter>
            <parameter name="cache_lifetime" xsi:type="text" visible="true">
                <label translate="true">Cache Lifetime (Seconds)</label>
                <description translate="true">
                    <![CDATA[Time in seconds between the widget updates.
                    <br/>In case of the dynamic recommendations, the setting applied only to the initial container.
                    <br/>If not set, equals to 86400 seconds (24 hours). To update widget instantly, go to Cache Management and clear Blocks HTML Output cache.]]>
                </description>
            </parameter>
        </parameters>
        <containers>
            <container name="content">
                <template name="grid" value="default" />
            </container>
            <container name="content.top">
                <template name="grid" value="default" />
            </container>
            <container name="content.bottom">
                <template name="grid" value="default" />
            </container>
            <container name="synerise.search.no_results">
                <template name="grid" value="default" />
            </container>
        </containers>
    </widget>
</widgets>
